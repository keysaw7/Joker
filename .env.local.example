# Clés API pour les adaptateurs IA (serveur uniquement).
# Copiez ce fichier en .env.local et renseignez les clés des fournisseurs que vous utilisez.

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Generative AI — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase — https://supabase.com/dashboard → ton projet → Settings → API
# Project URL → NEXT_PUBLIC_SUPABASE_URL
# anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Migrations Supabase (CLI) — une seule fois :
#   npx supabase login
#   npm run db:link -- --project-ref TON_PROJECT_REF
# Puis pour appliquer les migrations :
#   npm run db:push
